# NewsLet v3.0 - Configuracion de entorno
# Copia este archivo como .env y rellena los valores

# AI Provider
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (fallback, opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# NewsAPI (opcional)
NEWSAPI_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Base de datos
DATABASE_URL=sqlite:///./newslet.db

# Scheduler
FETCH_INTERVAL_MINUTES=30
DIGEST_HOUR=8

# AI Enrichment
RELEVANCE_THRESHOLD=5
ENRICH_ARTICLES=true
SCRAPE_FULL_TEXT=true

# Seguridad del panel (dejar vacio para acceso libre)
PANEL_PIN=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logs
LOG_FILE=logs/newslet.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
